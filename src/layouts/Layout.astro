---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  image?: string;
  canonicalUrl?: string;
}

const {
  title,
  description,
  image = '/og-image.png',
  canonicalUrl = Astro.url.href
} = Astro.props;

// Determine current active path for navigation highlight
const pathname = Astro.url.pathname;
const currentPath = pathname.replace(/\/$/, '') || '/';

const navItems = [
  { name: 'Home', href: '/' },
  { name: 'Projects', href: '/projects' },
  { name: 'Experience', href: '/experience' },
  { name: 'Contact', href: '/contact' }
];
---

<!doctype html>
<html lang="en" class="dark scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO Meta Tags -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.url.origin)} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalUrl} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL(image, Astro.url.origin)} />

    <!-- Google Material Symbols & Fonts -->
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
      rel="stylesheet"
    />
  </head>
  <body
    class="min-h-screen flex flex-col justify-between selection:bg-primary/30 selection:text-primary"
  >
    <!-- Skip to main content for accessibility -->
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 bg-primary text-on-primary px-4 py-2 rounded-md font-semibold z-[60]"
    >
      Skip to main content
    </a>

    <!-- Top Navigation Bar -->
    <nav
      class="bg-surface/50 backdrop-blur-xl border-b border-white/10 shadow-[0_0_30px_rgba(221,183,255,0.1)] sticky top-0 z-50 transition-all duration-300"
      id="main-nav"
    >
      <div
        class="flex justify-between items-center px-6 py-4 w-full max-w-[1200px] mx-auto"
      >
        <a
          href="/"
          class="text-2xl font-display font-bold text-primary select-none"
        >
          Suyog
        </a>

        <!-- Desktop Nav Links -->
        <div class="hidden md:flex gap-8 items-center">
          {
            navItems.map((item) => {
              const isActive = currentPath === item.href;
              return (
                <a
                  href={item.href}
                  class={
                    isActive
                      ? 'text-primary font-bold border-b-2 border-primary pb-1 font-display text-sm transition-all duration-300'
                      : 'text-on-surface-variant font-sans text-sm hover:text-primary transition-all duration-300 pb-1'
                  }
                >
                  {item.name}
                </a>
              );
            })
          }
        </div>

        <!-- Desktop Resume Link -->
        <a
          href="/resume.pdf"
          target="_blank"
          class="hidden md:flex bg-primary text-on-primary px-6 py-2 rounded-full font-display text-xs font-bold active:scale-95 transition-all hover:shadow-[0_0_20px_rgba(221,183,255,0.4)] cursor-pointer items-center justify-center"
        >
          Resume
        </a>

        <!-- Hamburger Button (Mobile) -->
        <button
          id="menu-toggle"
          class="md:hidden text-on-surface hover:text-primary focus:outline-none focus-visible:ring-2 focus-visible:ring-primary/50 cursor-pointer flex items-center justify-center p-2 rounded-md transition-colors"
          aria-label="Toggle navigation menu"
        >
          <!-- Hamburger Icon (three lines) -->
          <svg
            id="hamburger-icon"
            class="w-6 h-6 block"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            viewBox="0 0 24 24"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
          </svg>
          <!-- Close Icon (X) -->
          <svg
            id="close-icon"
            class="w-6 h-6 hidden"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            viewBox="0 0 24 24"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

      <!-- Mobile Navigation Dropdown -->
      <div
        id="mobile-menu"
        class="md:hidden absolute top-full left-0 w-full border-b border-white/10 bg-[#0b1326]/95 backdrop-blur-xl px-6 py-6 flex flex-col gap-4 shadow-[0_10px_30px_rgba(0,0,0,0.5)] transition-all duration-300 ease-out origin-top transform -translate-y-2 opacity-0 pointer-events-none"
      >
        {
          navItems.map((item) => {
            const isActive = currentPath === item.href;
            return (
              <a
                href={item.href}
                class={
                  isActive
                    ? 'text-primary font-bold font-display text-base transition-all duration-300 py-2 border-l-2 border-primary pl-3 block'
                    : 'text-on-surface-variant font-sans text-base hover:text-primary transition-all duration-300 py-2 pl-3 block'
                }
              >
                {item.name}
              </a>
            );
          })
        }
        <a
          href="/resume.pdf"
          target="_blank"
          class="mt-2 bg-primary text-on-primary py-3 rounded-lg font-display text-sm font-bold text-center hover:shadow-[0_0_20px_rgba(221,183,255,0.4)] transition-all flex items-center justify-center gap-2"
        >
          <svg
            class="w-4 h-4"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            viewBox="0 0 24 24"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3"
            />
          </svg>
          Resume
        </a>
      </div>
    </nav>

    <!-- Main Content -->
    <main id="main-content" class="flex-grow w-full relative">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-surface-container-lowest border-t border-white/5">
      <div
        class="flex flex-col md:flex-row justify-between items-center px-6 py-12 w-full max-w-[1200px] mx-auto gap-8"
      >
        <div class="space-y-3 text-center md:text-left">
          <div class="font-display text-xl text-primary font-bold">Suyog</div>
          <p class="text-on-surface-variant font-sans text-xs max-w-xs">
            &copy; {new Date().getFullYear()} AEM Full-Stack Developer. Built with
            precision and a passion for clean code.
          </p>
        </div>
        <div class="flex gap-8 text-xs font-display">
          <a
            href="https://github.com/Akio333"
            class="text-on-surface-variant hover:text-secondary transition-colors"
            >GitHub</a
          >
          <a
            href="https://www.linkedin.com/in/akio333/"
            class="text-on-surface-variant hover:text-secondary transition-colors"
            >LinkedIn</a
          >
          <a
            href="https://marketplace.visualstudio.com/publishers/Akio333"
            class="text-on-surface-variant hover:text-secondary transition-colors"
            >VS Code Marketplace</a
          >
        </div>
      </div>
    </footer>

    <script>
      // Navigation shrink micro-interaction
      const nav = document.getElementById('main-nav');
      if (nav) {
        window.addEventListener('scroll', () => {
          if (window.scrollY > 50) {
            nav.querySelector('.flex')?.classList.add('py-2');
            nav.querySelector('.flex')?.classList.remove('py-4');
          } else {
            nav.querySelector('.flex')?.classList.add('py-4');
            nav.querySelector('.flex')?.classList.remove('py-2');
          }
        });
      }

      // Mobile Menu Toggle logic
      const toggleBtn = document.getElementById('menu-toggle');
      const mobileMenu = document.getElementById('mobile-menu');
      const hamburgerIcon = document.getElementById('hamburger-icon');
      const closeIcon = document.getElementById('close-icon');

      if (toggleBtn && mobileMenu && hamburgerIcon && closeIcon) {
        toggleBtn.addEventListener('click', () => {
          const isOpen = mobileMenu.classList.contains('opacity-100');
          if (isOpen) {
            // Close menu
            mobileMenu.classList.remove('opacity-100', 'translate-y-0', 'pointer-events-auto');
            mobileMenu.classList.add('opacity-0', '-translate-y-2', 'pointer-events-none');
            hamburgerIcon.classList.remove('hidden');
            hamburgerIcon.classList.add('block');
            closeIcon.classList.remove('block');
            closeIcon.classList.add('hidden');
          } else {
            // Open menu
            mobileMenu.classList.remove('opacity-0', '-translate-y-2', 'pointer-events-none');
            mobileMenu.classList.add('opacity-100', 'translate-y-0', 'pointer-events-auto');
            hamburgerIcon.classList.remove('block');
            hamburgerIcon.classList.add('hidden');
            closeIcon.classList.remove('hidden');
            closeIcon.classList.add('block');
          }
        });
      }
    </script>
  </body>
</html>
