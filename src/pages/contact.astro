            type="email"
            required
          />
        </div>

        <div class="space-y-2">
          <label
            class="text-[10px] font-display font-semibold text-on-surface-variant ml-1 uppercase tracking-wider block"
            for="contact-message">Message</label
          >
          <textarea
            class="w-full bg-[#020617] border border-white/5 focus:border-primary focus:ring-1 focus:ring-primary rounded-xl px-4 py-3.5 text-sm text-on-surface outline-none transition-all resize-none"
            id="contact-message"
            placeholder="Tell me about your project..."
            rows="5"
            required></textarea>
        </div>

        <button
          class="w-full bg-primary text-on-primary font-display font-bold text-xs tracking-wider uppercase py-4 rounded-xl hover:scale-[0.98] transition-transform duration-300 shadow-[0_0_20px_rgba(221,183,255,0.25)] hover:shadow-neon-glow cursor-pointer"
          type="submit"
          id="submit-btn"
        >
          Send Message
        </button>
      </form>
    </div> -->
  </section>

  <script>
    function setupContactPageEvents() {
      document.querySelectorAll('.footprint-link').forEach((el) => {
        el.removeEventListener('click', handleFootprintClick);
        el.addEventListener('click', handleFootprintClick);
      });
    }

    function handleFootprintClick(e) {
      const platform = e.currentTarget.dataset.footprintPlatform;
      window.posthog?.capture('contact_footprint_clicked', { platform });
    }

    document.addEventListener('astro:page-load', setupContactPageEvents);
  </script>

  <!-- Script for form active status labels and submit animation -->
  <script is:inline>
    const form = document.getElementById('contact-form');
    const btn = document.getElementById('submit-btn');

    if (form && btn) {
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        const originalText = btn.innerText;
        btn.innerText = 'Sending...';
        btn.disabled = true;
        btn.classList.add('opacity-80', 'scale-95');

        setTimeout(() => {
          btn.innerText = 'Message Sent!';
          btn.classList.remove('bg-primary');
          btn.classList.add('bg-secondary', 'text-on-secondary');
          form.reset();

          setTimeout(() => {
            btn.innerText = originalText;
            btn.disabled = false;
            btn.classList.remove(
              'bg-secondary',
              'text-on-secondary',
              'opacity-80',
              'scale-95'
            );
            btn.classList.add('bg-primary');
          }, 3000);
        }, 1500);
      });
    }
  </script>
</Layout>
