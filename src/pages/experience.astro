            <div>
              <p class="text-[10px] font-display font-bold text-on-surface-variant uppercase tracking-wider">Adobe Certified</p>
              <p class="text-lg font-display font-bold text-on-surface">AEM Architect</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section> -->
</Layout>
